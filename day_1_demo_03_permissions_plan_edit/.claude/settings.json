{
  "permissions": {
    "deny": [
      "Write(docs/official/**)",
      "Edit(docs/official/**)",
      "Read(.env)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/docs-draft-only.ts"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/enforce-structure.ts"
          }
        ]
      }
    ]
  }
}
