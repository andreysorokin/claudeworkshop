{
  "extraKnownMarketplaces": {
    "org-shared": {
      "source": {
        "source": "directory",
        "path": "../shared"
      }
    }
  },
  "enabledPlugins": {
    "org-standards@org-shared": true
  },
  "permissions": {
    "deny": [
      "Edit(**/node_modules/**)",
      "Edit(dist/**)",
      "Edit(**/.env)"
    ]
  }
}
